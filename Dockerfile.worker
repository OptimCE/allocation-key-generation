# ---------- stage 1: build ----------
FROM python:3.12-slim AS builder

WORKDIR /build
COPY requirements/base.txt   requirements/base.txt
COPY requirements/worker.txt requirements/worker.txt

RUN pip install --no-cache-dir --prefix=/install -r requirements/worker.txt

# ---------- stage 2: runtime ----------
FROM python:3.12-slim

# tini gives us a real PID 1: forwards SIGTERM to the Python process and
# reaps zombies from any solver subprocesses cvxpy spawns.
RUN apt-get update \
    && apt-get install -y --no-install-recommends tini \
    && rm -rf /var/lib/apt/lists/*

# Security: non-root user
RUN groupadd -r app && useradd -r -g app -d /app -s /sbin/nologin app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Copy only installed packages from builder
COPY --from=builder /install /usr/local

# Copy application code (no api/, no main.py — worker has its own entrypoint)
COPY core/       core/
COPY algorithms/ algorithms/
COPY shared/     shared/
COPY worker/     worker/
COPY locales/    locales/

# Own everything by app user
RUN chown -R app:app /app
USER app

# Liveness: worker.main's queue-depth poller touches /tmp/worker.alive
# every ~15s while NATS is reachable. ~3 missed polls = unhealthy.
# start-period covers the bounded NATS connect retry window
# (_NATS_CONNECT_MAX_ATTEMPTS=10, ~10 min) plus algorithm autodiscovery.
HEALTHCHECK --interval=30s --timeout=5s --start-period=600s --retries=3 \
    CMD python -c "import os, time, sys; sys.exit(0 if time.time() - os.path.getmtime('/tmp/worker.alive') < 60 else 1)"

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python", "-m", "worker.main"]
